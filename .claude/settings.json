{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git push*)",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/scripts/check-public-leakage.sh\"",
            "timeout": 30,
            "statusMessage": "Scanning diff for internal leakage"
          }
        ]
      }
    ]
  }
}
